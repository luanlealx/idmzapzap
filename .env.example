# ===========================================
# IDM Portfolio Bot - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# ⚠️  NUNCA commite o arquivo .env no git!
# ===========================================

# Supabase (banco de dados)
# Pegue em: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # ⚠️ NUNCA exponha essa chave publicamente

# Anthropic (IA para entender mensagens)
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (conexão WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=idm-bot

# CoinGecko (preços de criptos - grátis)
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Server
PORT=3000
NODE_ENV=development

# 🔒 Admin whitelist (comma-separated phone numbers)
# During beta, only these numbers can use the bot.
# Leave empty to allow all users (production mode).
# Example: ADMIN_WHITELIST=5573999999999,5511888888888
ADMIN_WHITELIST=
